        pred_idx = _phase3_predictor.predict(X)[0]
        proba = _phase3_predictor.predict_proba(X)[0]
        label = _phase3_label_encoder.inverse_transform([pred_idx])[0]

        probabilities = {
            lbl: round(float(p), 4)
            for lbl, p in zip(_phase3_label_encoder.classes_, proba)
        }
        confidence = float(max(proba))

        imp = _phase3_predictor.feature_importance(_phase3_engineer.selected_features)
        explanation = explain_prediction(
            feature_values=feature_dict,
            feature_importances=imp,
            predicted_condition=label,
            confidence=confidence,
        )
        recs = _recommender.generate(label, probabilities, age) if _recommender else {}

        return jsonify({
