# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-secret-key

# Server
API_HOST=0.0.0.0
API_PORT=5001
FRONTEND_URL=http://localhost:3000

# Model Configuration
MODELS_DIR=models
DATA_DIR=data
MAX_CONTENT_LENGTH=16777216

# Audio Processing
FFMPEG_PATH=ffmpeg
AUDIO_SAMPLE_RATE=16000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
